# profile.env — profil d'identité dev WinCorp.
#
# LOCAL PAR MACHINE — NE JAMAIS committer ni partager (il décrit TON identité et TES accès).
# Copie ce fichier vers ~/.claude/profile.env puis renseigne TES valeurs.
#
# Effet : active la sync multi-dev (pull des skills partagés + miroir mémoire perso).
# Absent → comportement par défaut du mainteneur (rétro-compatible, rien ne change).
# Rollback de la logique multi-dev = supprimer ~/.claude/profile.env.

DEV_NAME=<ton-prenom-en-minuscules>
DEV_EMAIL_WINCORP=<toi>@wincorp.fr
DEV_TIERS=shared,personal
DEV_PERSONAL_REPO=<ton-compte-github>/<ton-miroir-prive>
HAS_ACCESS_GARM=true
HAS_ACCESS_VAULT=false
